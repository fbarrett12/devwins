generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Win {
  id       String   @id @default(cuid())
  title    String
  category Category

  situation String?
  task      String?
  action    String?
  result    String?

  impactMetric String?
  technologies String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Category {
  RELIABILITY
  PERFORMANCE
  COST_SAVINGS
  REVENUE
  LEADERSHIP
  DEBUGGING
  ARCHITECTURE
}
